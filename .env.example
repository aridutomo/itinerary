# ===== NextAuth =====
# Untuk dev lokal, NEXTAUTH_URL bisa http://localhost:3000
# Di Vercel, set ke domain produksi (mis. https://itinerary-anda.vercel.app)
NEXTAUTH_URL=http://localhost:3000
# Generate dengan: openssl rand -base64 32  (atau pakai online generator)
NEXTAUTH_SECRET=ganti-dengan-string-acak-panjang

# ===== Akun yang boleh login (max 5) =====
# USER_NAME_x opsional (untuk tampilan saja)
USER_ID_1=ari
USER_PASS_1=passwordrahasia
USER_NAME_1=Ari

USER_ID_2=istri
USER_PASS_2=passwordrahasia2
USER_NAME_2=Istri

# ===== Google Sheets =====
# Ambil dari URL Sheets: docs.google.com/spreadsheets/d/<ID INI>/edit
GOOGLE_SHEET_ID=
# Nama tab/sheet (dibuat otomatis bila belum ada).
# Trips = data rencana, Details = tujuan-tujuan di dalam rencana.
GOOGLE_SHEET_TRIPS_TAB=Trips
GOOGLE_SHEET_DETAILS_TAB=Details

# JSON service account FULL (1 baris). Cara cepat:
#   1. Download key JSON dari Google Cloud.
#   2. Buka di editor, copy seluruh isinya.
#   3. Paste di sini sebagai SATU baris (Vercel & Next.js bisa baca JSON multi-line via \n).
# CONTOH (potongan): {"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}
GOOGLE_SERVICE_ACCOUNT_JSON=
