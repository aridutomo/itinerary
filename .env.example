# Database Type (sheets | supabase)
DB_TYPE=supabase

# Supabase (New)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Sheets (Legacy - Optional fallback)
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TRIPS_TAB=Trips
GOOGLE_SHEET_DETAILS_TAB=Details
GOOGLE_SHEET_USERS_TAB=Users
GOOGLE_SHEET_NOTIFS_TAB=Notifications

# NextAuth
NEXTAUTH_SECRET=your-secret-key-at-least-32-chars
NEXTAUTH_URL=http://localhost:3000
